class TinyTransformer:

"""
Micro-Transformer: 2 layers, 4 heads, 64 dims.
All weights are ternary {-1,0,1}. Matmul is additions only.
"""
def __init__(self, vocab_size: int = 128, dim: int = 64, heads: int = 4, depth: int = 2):
self.dim = dim
self.heads = heads
self.depth = depth
self.vocab_size = vocab_size
# ROM-Burned weights (random but fixed seed for determinism)
random.seed(42)
self.w_emb = [[Ternary.quantize(random.uniform(-1, 1)) for _ in range(dim)] for _ in
range(vocab_size)]
self.w_q = [[[Ternary.quantize(random.uniform(-1, 1)) for _ in range(dim)] for _ in
range(dim)] for _ in range(depth)]
self.w_k = [[[Ternary.quantize(random.uniform(-1, 1)) for _ in range(dim)] for _ in
range(dim)] for _ in range(depth)]
self.w_v = [[[Ternary.quantize(random.uniform(-1, 1)) for _ in range(dim)] for _ in
range(dim)] for _ in range(depth)]
self.w_o = [[[Ternary.quantize(random.uniform(-1, 1)) for _ in range(dim)] for _ in
range(dim)] for _ in range(depth)]
self.w_ff1 = [[Ternary.quantize(random.uniform(-1, 1)) for _ in range(dim*2)] for _ in
range(dim)]
self.w_ff2 = [[Ternary.quantize(random.uniform(-1, 1)) for _ in range(dim)] for _ in
range(dim*2)]
# Positional encoding (fixed sine/cosine)
self.pos_enc = self._fixed_positional_encoding(128, dim)
def _fixed_positional_encoding(self, seq_len: int, dim: int) -> List[List[int]]:
enc = []
for pos in range(seq_len):
row = []
for i in range(dim):
angle = pos / (10000 ** (i / dim))
val = math.sin(angle) if i % 2 == 0 else math.cos(angle)
row.append(Ternary.quantize(val))
enc.append(row)
return enc
def _self_attention(self, x: List[List[int]], layer: int) -> List[List[int]]:
"""Ternary attention: Q,K,V are ternary. Score = XNOR popcount."""
seq_len = len(x)
head_dim = self.dim // self.heads
output = [[0]*self.dim for _ in range(seq_len)]


for h in range(self.heads):
start = h * head_dim
end = start + head_dim
for i in range(seq_len):
q = x[i][start:end]
scores = []
for j in range(seq_len):
k = x[j][start:end]
score = Ternary.xnor_popcount(q, k) # Integer only
scores.append(score)
# Softmax approximation: just use sign/sum (ternary)
sum_scores = sum(scores)
attn_weight = 1 if sum_scores > 0 else -1 if sum_scores < 0 else 0
# Apply to V
for j in range(seq_len):
v = x[j][start:end]
if attn_weight == 1:
for idx in range(head_dim):
output[i][start+idx] += v[idx]
elif attn_weight == -1:
for idx in range(head_dim):
output[i][start+idx] -= v[idx]
# Clip to ternary
return [[Ternary.quantize(v) for v in row] for row in output]
def forward(self, token_ids: List[int]) -> List[int]:
"""Full forward pass. Returns ternary vector output."""
# Embedding
x = [self.w_emb[t] for t in token_ids[:64]]
seq_len = len(x)
# Add positional encoding
for i in range(seq_len):
for j in range(self.dim):
x[i][j] += self.pos_enc[i % 128][j]
x[i][j] = Ternary.quantize(x[i][j])
# 2 Layers of attention + FFN
for layer in range(self.depth):
# Self-attention
attn_out = self._self_attention(x, layer)
# Residual + FFN (ternary approximate)
for i in range(seq_len):
for j in range(self.dim):
# FFN: 2 layers with ternary weights
hidden = 0
for k in range(self.dim*2):
hidden += self.w_ff1[j][k] * attn_out[i][j] # simulates matmul

hidden = Ternary.quantize(hidden)
out_val = 0
for k in range(self.dim):
out_val += self.w_ff2[j][k] * hidden
out_val = Ternary.quantize(out_val)
x[i][j] = Ternary.quantize(x[i][j] + out_val)
# Pooling: average (sign sum) to single vector
final_vec = [0]*self.dim
for i in range(seq_len):
for j in range(self.dim):
final_vec[j] += x[i][j]
return [Ternary.quantize(v / seq_len) for v in final_vec]
