class FiniteStateMachine:


Hard real-time scheduler. Enforces WCET via state transition cycle counts.
States: IDLE -> FUZZIFY -> SCHEDULE -> EXECUTE -> POWER_DOWN.
"""
class State(Enum):
IDLE = 0
FUZZIFY = 1
SCHEDULE = 2
EXECUTE = 3
POWER_DOWN = 4
TIMEOUT = 5
def __init__(self):
self.state = self.State.IDLE
self.cycle_counter = 0
self.allocated_cycles = {
self.State.FUZZIFY: 50,
self.State.SCHEDULE: 30,
self.State.EXECUTE: 280,
self.State.POWER_DOWN: 40,
}
self.total_cycles = 0
def transition(self, target_state: State) -> bool:
"""
Move to target state. Adds cycle cost.
Returns False if WCET exceeded (Timeout).
"""
cost = self.allocated_cycles.get(target_state, 10)
self.cycle_counter += cost
self.total_cycles += cost
if self.total_cycles > WCET.CYCLES_TOTAL_MAX:
self.state = self.State.TIMEOUT
return False
self.state = target_state
return True
def reset(self):
self.state = self.State.IDLE
self.cycle_counter = 0
self.total_cles = 0
