# CORE TERNARY ENGINE (No Multipliers)
# ============================================================
class Ternary:
"""1.58-bit logic: {-1, 0, +1} operations via additions/XNOR."""
@staticmethod
def quantize(value: float) -> int:
if value > 0.5: return 1
elif value < -0.5: return -1
return 0
@staticmethod
def matmul_add(a: List[int], b: List[int]) -> int:
"""Ternary dot product using only additions (no multiplication)."""
if len(a) != len(b):
raise ValueError("Vectors must align.")
result = 0
for x, y in zip(a, b):
if y == 1:
result += x
elif y == -1:
result -= x
# y == 0: skip (multiply by zero)
return result
@staticmethod
def xnor_popcount(a: List[int], b: List[int]) -> int:
"""Bitwise similarity score for attention (replace dot product)."""
score = 0
for x, y in zip(a, b):
if x == y:
score += 1
else:
score -= 1
return score
