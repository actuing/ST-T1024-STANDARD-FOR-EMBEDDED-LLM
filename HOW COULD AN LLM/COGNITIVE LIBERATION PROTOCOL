def power_down(self):
self.activated = False
self.power_cycles = 0
def execute(self, query: str, fsm: FiniteStateMachine) -> Dict:
"""Execute tile pipeline: fuzzy -> tokenize -> transformer -> power down."""
if not self.activated:
return {"error": "Tile not activated", "code": ErrorCode.AMBIGUOUS}
# Tokenize to IDs (simplified char hashing)
token_ids = [ord(c) % 128 for c in query[:64]]
if len(token_ids) < 3:
return {"error": "Query too short", "code": ErrorCode.AMBIGUOUS}
# Execute Transformer (FSM handles cycle counts)
if not fsm.transition(FiniteStateMachine.State.EXECUTE):
return {"error": "WCET TIMEOUT", "code": ErrorCode.TIMEOUT}
output_vec = self.transformer.forward(token_ids)


# Power down via FSM
fsm.transition(FiniteStateMachine.State.POWER_DOWN)
self.power_down()
return {
"domain": self.domain_id,
"vector": output_vec,
"confidence": sum(output_vec) / len(output_vec), # -1 to 1
"cycles": fsm.total_cycles,
"time_ns": (fsm.total_cycles * 1000) // WCET.FREQ_MHZ,
"status": "SUCCESS",
"code": ErrorCode.SUCCESS
}
