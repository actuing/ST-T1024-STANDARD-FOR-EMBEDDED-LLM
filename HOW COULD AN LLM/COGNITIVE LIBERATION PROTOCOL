0.6},
}
self.general_weight = 0.3
def evaluate(self, query: str) -> Tuple[str, float]:
"""Returns (Domain_ID, Confidence_Score)."""
query_lower = query.lower()
scores = {}
for domain, config in self.membership.items():
match_count = sum(1 for term in config["terms"] if term in query_lower)
raw_score = (match_count / len(config["terms"])) * config["weight"]
scores[domain] = min(raw_score, 1.0)
# General catch-all
scores["GENERAL"] = self.general_weight + (len(query.split()) / 100) * 0.1
best_domain = max(scores, key=scores.get)
best_conf = scores[best_domain]
return best_domain, best_conf
