class TernaryQuantizer:
    def transform_model(self, float_weights: np.ndarray) -> np.ndarray:
        # Map to {-1, 0, +1} via deterministic threshold
        return np.sign(float_weights).astype(np.int8)
    
    def rewrite_kernel(self, original_kernel: str) -> str:
        # Replace multiplications with additions/bit-shifts
        # Original: output += weight * input
        # New: output += ternary_weight  # Just add/subtract
        return original_kernel.replace('*', ' + ')
        
    def eliminate_fpu(self, pipeline_code: str) -> str:
        # Remove all float operations, force integer/bitwise only
        return self.bitwise_rewrite(pipeline_code)


