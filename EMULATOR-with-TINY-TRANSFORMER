class STT1024:

    def __init__(self):

        self.fis = TernaryFIS()

        self.fsm = DeterministicFSM()

        self.tiles = {

            "PHYSICS": Tile(

                "PHYSICS",

                [
                    "energy",
                    "force",
                    "heat",
                    "entropy",
                    "thermodynamics"
                ],

                {
                    "fact1":
                    "Energy is conserved"
                }
            ),

            "LAW": Tile(

                "LAW",

                [
                    "law",
                    "constitution",
                    "rights"
                ],

                {
                    "fact1":
                    "Constitutions define authority"
                }
            ),

            "MATH": Tile(

                "MATH",

                [
                    "equation",
                    "proof",
                    "theorem"
                ],

                {
                    "fact1":
                    "A=A"
                }
            )
        }

    def run_query(self,
                  query):

        self.fsm.transition(
            "TRIAGE"
        )

        domain = self.fis.infer(
            query
        )

        if domain is None:

            self.fsm.transition(
                "ERROR"
            )

            return {

                "status":"ERROR",

                "error":"0x-AMBIG"
            }

        self.fsm.transition(
            "ACTIVATE_TILE"
        )

        tile = self.tiles[domain]

        tile.power_on()

        self.fsm.transition(
            "RUN_TRANSFORMER"
        )

        result = tile.execute(
            query
        )

        self.fsm.transition(
            "VERIFY"
        )

        self.fsm.transition(
            "POWER_DOWN"
        )

        tile.power_off()

        return {

            "status":"SUCCESS",

            "domain":domain,

            "cycles":self.fsm.cycles,

            "result":result
        }



