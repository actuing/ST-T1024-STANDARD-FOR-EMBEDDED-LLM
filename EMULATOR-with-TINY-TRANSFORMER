from typing import Dict, List, Optional

# =====================================================
# TERNARY FIS
# =====================================================

class TernaryFIS:

    def __init__(self):

        self.rules = {

            "PHYSICS": [
                "energy",
                "force",
                "heat",
                "entropy",
                "thermodynamics"
            ],

            "LAW": [
                "law",
                "constitution",
                "rights",
                "governance",
                "sovereignty"
            ],

            "MATH": [
                "equation",
                "theorem",
                "proof",
                "calculus",
                "mathematics"
            ]
        }

    def infer(self, query:str):

        q = query.lower()

        scores = {}

        for domain, keywords in self.rules.items():

            count = sum(
                1 for kw in keywords
                if kw in q
            )

            if count >= 2:
                scores[domain] = 1

            elif count == 1:
                scores[domain] = 0

            else:
                scores[domain] = -1

        best = max(scores, key=scores.get)

        if scores[best] <= 0:
            return None

        return best






# =====================================================
# FSM
# =====================================================

class DeterministicFSM:

    STATES = [

        "IDLE",

        "TRIAGE",

        "ACTIVATE_TILE",

        "RUN_TRANSFORMER",

        "VERIFY",

        "POWER_DOWN",

        "ERROR"
    ]

    def __init__(self):

        self.state = "IDLE"

        self.cycles = 0

        self.max_cycles = 400

    def transition(self, state):

        self.cycles += 1

        if self.cycles > self.max_cycles:

            self.state = "ERROR"

            raise RuntimeError("WCET VIOLATION")

        self.state = state





# =====================================================
# TINY TRANSFORMER
# =====================================================

class TinyTransformer:

    """
    Emulator only.

    Represents a small domain-specific transformer.
    """

    def __init__(self,
                 domain:str,
                 vocabulary:List[str]):

        self.domain = domain

        self.vocabulary = set(vocabulary)

    def tokenize(self,
                 query:str):

        return [

            token

            for token in query.lower().split()

            if token in self.vocabulary
        ]

    def forward(self,
                query:str):

        tokens = self.tokenize(query)

        return {

            "domain": self.domain,

            "tokens": tokens,

            "token_count": len(tokens)
        }







# =====================================================
# TILE
# =====================================================

class Tile:

    def __init__(self,
                 domain,
                 vocabulary,
                 rom):

        self.domain = domain

        self.powered = False

        self.rom = rom

        self.sram = {}

        self.transformer = TinyTransformer(
            domain,
            vocabulary
        )

    def power_on(self):

        self.powered = True

    def power_off(self):

        self.powered = False

        self.sram.clear()

    def execute(self,
                query):

        if not self.powered:

            raise RuntimeError(
                "Tile not powered"
            )

        result = self.transformer.forward(
            query
        )

        facts = list(self.rom.values())

        return {

            "transformer": result,

            "facts": facts[:3]
        }




