4. Implementation Guide: Memory-Mapped Conduits

4.1 Zone 0 → Zone 1 FIFO (C0)

Memory Map (Zone 0 Output Registers):

Address Field Description
0x0000 FIFO_STATUS Bits: 0 = empty, 1 = data ready, 2 = overflow
0x0004 FIFO_DATA 32-bit output word (deterministic inference result)
0x0008 TILE_ID 16-bit identifier for the active tile (0xFFFF = none)
0x000C TIMESTAMP 64-bit cycle counter (for AET verification)
0x0010 ERROR_CODE 0 = OK, 0x-AMBIG = ambiguous, 0x-ERR = fault

FIFO Operation (Hardware):

```verilog
// Zone 0 FIFO Controller
module fifo_controller (
    input clk,
    input reset,
    input [31:0] inference_result,
    input [15:0] tile_id,
    input [63:0] timestamp,
    input [7:0] error_code,
    output reg [31:0] fifo_data,
    output reg fifo_ready,
    input fifo_ack
);

// Write only when inference complete
always @(posedge clk) begin
    if (inference_complete && !fifo_ready) begin
        fifo_data <= inference_result;
        fifo_ready <= 1'b1;
    end
    if (fifo_ack && fifo_ready) begin
        fifo_ready <= 1'b0;
    end
end

endmodule
```

Zone 1 Read Code (C):

```c
// poll_zone0_fifo.c
#include <stdint.h>
#include "memory_map.h"  // Defines ZONE0_BASE

typedef struct {
    uint32_t status;
    uint32_t data;
    uint16_t tile_id;
    uint64_t timestamp;
    uint8_t error_code;
} FIFO_Registers;

#define FIFO_BASE ((volatile FIFO_Registers*) ZONE0_BASE)

uint32_t read_zone0_output(void) {
    // Wait for data ready (with watchdog timeout)
    while (!(FIFO_BASE->status & 0x01)) {
        // Increment watchdog counter
        if (watchdog_timer_expired()) {
            fail_safe_assert();  // Set outputs to 0V/0%
            return 0;
        }
    }
    
    // Read data and acknowledge
    uint32_t result = FIFO_BASE->data;
    FIFO_BASE->status &= ~0x01;  // Clear ready flag
    
    // Check error code
    if (FIFO_BASE->error_code == 0x0A) {  // 0x-AMBIG
        fail_safe_assert();
        return 0;
    }
    
    return result;
}
```

