Phase 2: Integrate and Test

2.1 Main Loop (Bare-Metal)

```c
// main.c
#include <stdio.h>
#include "intent_harvesting.h"
#include "fis_triage.h"
#include "fsm_scheduler.h"
#include "ternary_engine.h"
#include "tile_memory.h"

// Global state — deterministic, temperature = 0.0
FSMMachine g_fsm;
TileMemory g_tiles[MAX_TILES];
uint8_t g_system_ready = 0;

int main(void) {
    // 1. System initialization
    system_clock_init();
    fsm_init(&g_fsm);
    tile_memory_init(g_tiles, MAX_TILES);
    
    g_system_ready = 1;
    
    // 2. Main loop — deterministic, round after round
    while (1) {
        // Wait for input (interrupt or polling)
        if (query_available()) {
            QueryIntent intent = harvest_intent(get_query());
            
            // 3. Run the 6-step pipeline
            uint8_t complete = 0;
            while (!complete) {
                complete = fsm_step(&g_fsm, &intent);
                // Hardware-enforced WCET check
                fsm_enforce_wcet(&g_fsm);
            }
            
            // 4. Output result
            if (g_fsm.error_code == 0) {
                output_result(g_fsm.active_tile);
            } else if (g_fsm.error_code == 0x-AMBIG) {
                // Ambiguous query — return hard error, no hallucination
                output_error("0x-AMBIG");
            }
            
            // 5. Power-down — 0V idle
            tile_power_off(&g_tiles[g_fsm.active_tile]);
            fsm_init(&g_fsm);  // Reset for next query
        }
    }
}
```

2.2 RTOS Integration (Optional)

If using an RTOS, ensure the FSM runs in a high-priority, non-preemptible task to maintain AET:

```c
// FreeRTOS example
void st_t1024_task(void* pvParameters) {
    TickType_t xLastWakeTime = xTaskGetTickCount();
    const TickType_t xFrequency = pdMS_TO_TICKS(1);  // 1 ms period
    
    for (;;) {
        vTaskDelayUntil(&xLastWakeTime, xFrequency);
        
        // Run FSM step — must complete within WCET
        if (query_pending) {
            fsm_step(&g_fsm, &pending_intent);
            fsm_enforce_wcet(&g_fsm);
        }
    }
}
```

