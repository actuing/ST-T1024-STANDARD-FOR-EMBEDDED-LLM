Phase 1: Port the Core Pipeline

1.1 Intent Harvesting

```c
// intent_harvesting.h
#ifndef INTENT_HARVESTING_H
#define INTENT_HARVESTING_H

#include <stdint.h>
#include <string.h>

#define MAX_QUERY_LEN 256

typedef struct {
    char raw[MAX_QUERY_LEN];
    uint16_t length;
    uint32_t hash;  // For deterministic routing
} QueryIntent;

// Normalize input — remove whitespace, convert to lowercase
QueryIntent harvest_intent(const char* input);

#endif
```

1.2 FIS Triage (Fuzzy Inference System)

The FIS is a deterministic rule set — not a stochastic neural net. It routes queries to the correct domain tile.

```c
// fis_triage.h
#ifndef FIS_TRIAGE_H
#define FIS_TRIAGE_H

#include <stdint.h>

#define MAX_TILES 1024
#define TILE_UNKNOWN 0xFFFF

typedef struct {
    uint16_t tile_id;
    uint8_t confidence;  // 0-255, deterministic threshold
} TriageResult;

// Domain tile identifiers
typedef enum {
    TILE_MATH = 0,
    TILE_MEDICINE = 1,
    TILE_LAW = 2,
    TILE_HARDWARE = 3,
    TILE_PHYSICS = 4,
    // ... up to 1024 tiles
} TileDomain;

// FIS rule — deterministic matching
TriageResult fis_triage(const QueryIntent* intent);

#endif
```

Implementation principle: The FIS uses a finite set of fuzzy rules that are formally verifiable using model-checking tools (e.g., TLA+). This eliminates the "misrouting" hazard — a query cannot be sent to the wrong tile.

1.3 FSM Scheduling (Finite State Machine)

The FSM enforces AET (Assured Execution Time) — a hardware-guaranteed timing bound.

```c
// fsm_scheduler.h
#ifndef FSM_SCHEDULER_H
#define FSM_SCHEDULER_H

#include <stdint.h>

#define WCET_CYCLES 800  // Worst-case execution time in ns
#define AET_CYCLES   680 // Assured execution time (measured)

typedef enum {
    STATE_IDLE = 0,
    STATE_HARVEST = 1,
    STATE_TRIAGE = 2,
    STATE_SCHEDULE = 3,
    STATE_EXECUTE = 4,
    STATE_POWERDOWN = 5,
    STATE_ERROR = 6
} FSMState;

typedef struct {
    FSMState current_state;
    uint32_t cycle_counter;
    uint16_t active_tile;
    uint8_t error_code;
} FSMMachine;

// Initialize FSM — sets temperature = 0.0 (deterministic mode)
void fsm_init(FSMMachine* fsm);

// Run one scheduling cycle — returns 1 if complete, 0 if仍在执行
uint8_t fsm_step(FSMMachine* fsm, const QueryIntent* intent);

// Hardware-enforced cycle counter — halts if WCET exceeded
void fsm_enforce_wcet(FSMMachine* fsm);

#endif
```

Critical: The FSM cycle counter is hardware-enforced — not a software "best effort." This is what makes ST-T1024 certifiable under ISO 26262 (ASIL-D) and IEC 61508 (SIL 3).

1.4 Ternary Engine (No Multipliers)

ST-T1024 uses 1.58-bit ternary logic (-1, 0, +1) — pure addition/subtraction and XNOR-based attention. No floating-point multipliers.

```c
// ternary_engine.h
#ifndef TERNARY_ENGINE_H
#define TERNARY_ENGINE_H

#include <stdint.h>

// Ternary values: -1, 0, +1
typedef int8_t ternary_t;

// XNOR-based attention — no multiplication
// Returns: -1, 0, or +1
ternary_t ternary_xnor(ternary_t a, ternary_t b);

// Popcount for ternary vectors
uint32_t ternary_popcount(const ternary_t* vec, uint16_t len);

// Ternary matrix-vector multiply — addition/subtraction only
void ternary_matvec(const ternary_t* matrix, 
                    const ternary_t* vector,
                    ternary_t* result,
                    uint16_t rows, uint16_t cols);

#endif
```

Why this matters: Eliminating floating-point reduces silicon area by ~90% and enables deployment on $2 RISC-V microcontrollers.

1.5 Tile Memory Management

ST-T1024 uses a 75% ROM / 25% SRAM split:

```c
// tile_memory.h
#ifndef TILE_MEMORY_H
#define TILE_MEMORY_H

#include <stdint.h>

#define TILE_SIZE_KB 700   // 0.7 MB total per tile
#define ROM_RATIO 0.75f    // 75% immutable
#define SRAM_RATIO 0.25f   // 25% sovereign updates

typedef struct {
    const uint8_t* rom_base;   // Immutable "Brutal Facts"
    uint8_t* sram_base;        // Mutable, encrypted updates
    uint16_t rom_size;
    uint16_t sram_size;
    uint8_t tile_id;
    uint8_t active;            // 1 if powered on
} TileMemory;

// Activate tile — power-on in <5 ns
void tile_power_on(TileMemory* tile);

// Power-down tile — drop to 0V immediately
void tile_power_off(TileMemory* tile);

// Sovereign update (SK-1024 protocol) — encrypted packet only
uint8_t tile_sovereign_update(TileMemory* tile, const uint8_t* encrypted_packet);

#endif
```

The SK-1024 protocol restricts SRAM model updates to National Authority encrypted packets — full state control.

