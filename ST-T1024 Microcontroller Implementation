8. Power Management

ST-T1024 achieves 99.9% power gating. Implementation:

```c
// power_gating.h
#ifndef POWER_GATING_H
#define POWER_GATING_H

#include <stdint.h>

// Wake time: <5 ns from 0V to active
#define WAKE_TIME_NS 5

// Power gate control
typedef struct {
    volatile uint32_t* pwr_ctrl_reg;
    uint8_t tile_id;
    uint8_t is_active;
} PowerGate;

// Wake tile — <5 ns
void power_gate_on(PowerGate* pg) {
    *pg->pwr_ctrl_reg |= (1 << pg->tile_id);
    // Hardware ensures <5 ns wake time
    pg->is_active = 1;
}

// Power down — immediate 0V
void power_gate_off(PowerGate* pg) {
    *pg->pwr_ctrl_reg &= ~(1 << pg->tile_id);
    pg->is_active = 0;
}

#endif
```

