Always-on AI Not practical ✅ Practical (µW average)

Power Gating Implementation

```c
// From the implementation guide
#include "power_gating.h"

void tile_power_on(TileMemory* tile) {
    // Hardware wake in <5 ns
    *power_ctrl_reg |= (1 << tile->tile_id);
    tile->active = 1;
}

void tile_power_off(TileMemory* tile) {
    // Immediate 0V power-down
    *power_ctrl_reg &= ~(1 << tile->tile_id);
    tile->active = 0;
}

// Main loop with power management
int main(void) {
    while (1) {
        if (query_available()) {
            // Power up only the needed tile
            QueryIntent intent = harvest_intent(get_query());
            DomainID domain = fis_triage(&intent);
            
            // Activate tile (<5 ns)
            tile_power_on(&tiles[domain]);
            
            // Execute (680 ns)
            Response response = tiny_transformer_forward(&tiles[domain], &intent);
            
            // Immediate power-down (0V)
            tile_power_off(&tiles[domain]);
            
            // Return response
            output_result(response);
        }
    }
}
```

